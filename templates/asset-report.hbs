<div class="pmw-container">
  <div class="pmw-header">
    <div class="pmw-toolbar">
      <div class="pmw-summary">
        <span>Assets outside world folder: <strong>{{totalFound}}</strong></span>
        <span class="pmw-sep">|</span>
        <span class="pmw-external-count">External URLs: <strong>{{totalExternal}}</strong></span>
        <span class="pmw-sep">|</span>
        <span class="pmw-wildcard-count">Wildcards resolved: <strong>{{totalWildcard}}</strong></span>
        {{#if linkCheckDone}}
        <span class="pmw-sep">|</span>
        <span class="pmw-broken-count {{#if totalBroken}}pmw-broken-count--has-broken{{/if}}">
          Broken: <strong>{{totalBroken}}</strong>
        </span>
        {{/if}}
        {{#if totalPossibleMatches}}
        <span class="pmw-sep">|</span>
        <span class="pmw-match-count">Possible Matches: <strong>{{totalPossibleMatches}}</strong></span>
        {{#if totalConfirmed}}
        <span class="pmw-sep">|</span>
        <span class="pmw-confirmed-count">Confirmed: <strong>{{totalConfirmed}}</strong></span>
        {{/if}}
        {{/if}}
        {{#if copyDone}}
        <span class="pmw-sep">|</span>
        <span class="pmw-copy-ok">Copied: <strong>{{copySuccessCount}}</strong></span>
        {{#if copyErrorCount}}
        <span class="pmw-sep">|</span>
        <span class="pmw-copy-err">Failed: <strong>{{copyErrorCount}}</strong></span>
        {{/if}}
        {{/if}}
      </div>
      <div class="pmw-toolbar-btns">
        <button id="pmw-check-links-btn" class="pmw-action-btn {{#if checkingLinks}}pmw-action-btn--disabled{{/if}}" {{#if checkingLinks}}disabled{{/if}}>
          {{#if checkingLinks}}
            <i class="fa-solid fa-spinner fa-spin"></i> Checking…
          {{else}}
            <i class="fa-solid fa-link"></i> Check Links
          {{/if}}
        </button>
        <button id="pmw-fix-broken-btn" class="pmw-action-btn pmw-action-btn--fix {{#if fixingBroken}}pmw-action-btn--disabled{{/if}}" {{#if fixingBroken}}disabled{{/if}}>
          {{#if fixingBroken}}
            <i class="fa-solid fa-spinner fa-spin"></i> Searching…
          {{else}}
            <i class="fa-solid fa-wrench"></i> Fix Broken
          {{/if}}
        </button>
        <button id="pmw-copy-btn" class="pmw-action-btn {{#if copying}}pmw-action-btn--disabled{{/if}}" {{#if copying}}disabled{{/if}}>
          {{#if copying}}
            <i class="fa-solid fa-spinner fa-spin"></i> Copying…
          {{else}}
            <i class="fa-solid fa-copy"></i> Copy Files
          {{/if}}
        </button>
      </div>
    </div>

    <div class="pmw-tabs">
      {{#each tabs}}
      <button class="pmw-tab {{#if active}}active{{/if}}" data-tab="{{id}}">
        {{label}}<span class="pmw-badge">{{count}}</span>
      </button>
      {{/each}}
    </div>

    {{#if showSceneSubFilters}}
    <div class="pmw-sub-tabs">
      {{#each sceneSubFilters}}
      <button class="pmw-sub-tab {{#if active}}active{{/if}}" data-sub="{{id}}">
        {{label}}<span class="pmw-badge pmw-badge--sub">{{count}}</span>
      </button>
      {{/each}}
    </div>
    {{/if}}

    {{#if showCompendiumSubFilters}}
    <div class="pmw-sub-tabs pmw-sub-tabs--compendium">
      {{#each compendiumSubFilters}}
      <button class="pmw-sub-tab {{#if active}}active{{/if}}" data-sub="{{id}}">
        {{label}}<span class="pmw-badge pmw-badge--sub">{{count}}</span>
      </button>
      {{/each}}
    </div>
    {{/if}}

    <div class="pmw-status-filters">
      {{#each statusFilters}}
      <button class="pmw-status-filter pmw-status-filter--{{id}} {{#if active}}active{{/if}}" data-status="{{id}}">
        {{label}}<span class="pmw-badge pmw-badge--status">{{count}}</span>
      </button>
      {{/each}}
    </div>
  </div>

  <div class="pmw-table-wrapper">
    {{#if visibleAssets.length}}
    <table class="pmw-table">
      <thead>
        <tr>
          <th>Document</th>
          <th>Type</th>
          <th>Current Path</th>
          <th>Expected New Path</th>
          <th class="pmw-th-status">Status</th>
        </tr>
      </thead>
      <tbody>
        {{#each visibleAssets}}
        <tr class="pmw-row {{#if isExternal}}pmw-external{{/if}} {{#if isWildcard}}pmw-wildcard{{/if}} {{#if isBroken}}pmw-broken{{/if}} {{#if matchConfirmed}}pmw-confirmed{{/if}}">
          <td class="pmw-doc-name" title="{{documentName}}">{{documentName}}</td>
          <td><span class="pmw-type pmw-type--{{type}}">{{type}}</span></td>
          <td class="pmw-path pmw-path--original" title="{{originalPath}}">
            {{originalPath}}
            {{#if isWildcard}}<span class="pmw-wildcard-badge" title="Resolved from wildcard: {{wildcardPath}}">&#x26A1; wildcard</span>{{/if}}
          </td>
          <td class="pmw-path pmw-path--proposed" title="{{proposedPath}}">{{proposedPath}}</td>
          <td class="pmw-status">
            {{!-- Preview icon first --}}
            {{#if (and isBroken (not possibleMatch) (not matchConfirmed))}}
              <button class="pmw-preview-btn pmw-preview-btn--disabled" disabled title="File not found — cannot preview">
                <i class="fa-solid fa-magnifying-glass"></i>
              </button>
            {{else}}
              <button class="pmw-preview-btn" data-path="{{previewPath}}" data-type="{{type}}" title="Preview asset">
                <i class="fa-solid fa-magnifying-glass"></i>
              </button>
            {{/if}}
            {{!-- Status tag --}}
            {{#if matchConfirmed}}
              <span class="pmw-tag pmw-tag--confirmed">&#x2713; Confirmed</span>
            {{else if possibleMatch}}
              <span class="pmw-tag pmw-tag--possible">&#x3F; Possible Match</span>
              <span class="pmw-match-path" title="{{possibleMatch}}">{{possibleMatch}}</span>
              <button class="pmw-confirm-match-btn" data-original="{{originalPath}}" title="Confirm this match is correct">
                <i class="fa-solid fa-check"></i> Confirm
              </button>
            {{else if isBroken}}
              <span class="pmw-tag pmw-tag--broken">&#x2717; Broken</span>
            {{else if copyStatus}}
              {{#if (eq copyStatus 'success')}}
                <span class="pmw-tag pmw-tag--copied">&#x2713; Copied</span>
              {{else}}
                <span class="pmw-tag pmw-tag--error">&#x2717; Failed</span>
              {{/if}}
            {{else}}
              {{#if isExternal}}
                <span class="pmw-tag pmw-tag--warn" title="Will attempt fetch; may fail if CORS is blocked">⚠ External URL</span>
              {{else}}
                <span class="pmw-tag pmw-tag--ok">✓ Copyable</span>
              {{/if}}
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{else}}
    <p class="pmw-empty">No assets match the current filters.</p>
    {{/if}}
  </div>
</div>
